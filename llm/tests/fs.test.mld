# Tests for @mlld/fs module

@import { * } from "../modules/test.mld.md"
@import { * } from "../modules/fs.mld.md"

## Test fileExists
# Test with files that should exist on most systems
@data test_file_exists_etc_hosts = @ok(@fileExists("/etc/hosts"))
@data test_file_exists_not_found = @notOk(@fileExists("/tmp/definitely-does-not-exist-12345.txt"))

## Test dirExists  
# Test with directories that should exist on most systems
@data test_dir_exists_tmp = @ok(@dirExists("/tmp"))
@data test_dir_exists_root = @ok(@dirExists("/"))
@data test_dir_exists_not_found = @notOk(@dirExists("/tmp/definitely-does-not-exist-12345"))

## Test pathExists
# Should work for both files and directories
@data test_path_exists_tmp = @ok(@pathExists("/tmp"))
@data test_path_exists_etc = @ok(@pathExists("/etc"))
@data test_path_exists_not_found = @notOk(@pathExists("/definitely/does/not/exist"))