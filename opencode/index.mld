needs { sh }

>> ── Stream format adapter for Opencode CLI NDJSON events (opencode run --format json) ──
var @opencodeStreamFormat = {
  name: "opencode",
  format: "ndjson",
  schemas: [
    {
      kind: "message",
      matchPath: "type",
      matchValue: "text",
      extract: { chunk: "part.text" }
    },
    {
      kind: "metadata",
      matchPath: "type",
      matchValue: "step_start",
      extract: { sessionId: "sessionID" }
    },
    {
      kind: "metadata",
      matchPath: "type",
      matchValue: "step_finish",
      extract: {
        inputTokens: "part.tokens.input",
        outputTokens: "part.tokens.output",
        totalTokens: "part.tokens.total",
        cost: "part.cost"
      }
    }
  ]
}

>> ── Session / resume helpers ──

>> Opencode session ids look like `ses_<base36>` and are case-sensitive,
>> so we trim but preserve case.
exe @normalizeOpencodeSessionId(sessionId) = js {
  if (typeof sessionId !== "string") return null;
  const trimmed = sessionId.trim();
  return trimmed || null;
}

>> Parses opencode run --format json NDJSON output for session id, final text, and usage.
>> Concatenates every `text` event's `part.text` in order to reconstruct the agent message.
exe @parseOpencodeJsonl(raw) = js {
  const result = { sessionId: null, text: "", inputTokens: null, outputTokens: null, totalTokens: null, cost: null };
  if (typeof raw !== "string" || !raw) return result;
  const chunks = [];
  for (const line of raw.split(/\r?\n/)) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    let obj;
    try { obj = JSON.parse(trimmed); } catch { continue; }
    if (!obj || typeof obj !== "object") continue;
    if (!result.sessionId && typeof obj.sessionID === "string") {
      result.sessionId = obj.sessionID;
    }
    if (obj.type === "text" && obj.part && typeof obj.part.text === "string") {
      chunks.push(obj.part.text);
    } else if (obj.type === "step_finish" && obj.part && obj.part.tokens && typeof obj.part.tokens === "object") {
      const t = obj.part.tokens;
      if (typeof t.input === "number") result.inputTokens = t.input;
      if (typeof t.output === "number") result.outputTokens = t.output;
      if (typeof t.total === "number") result.totalTokens = t.total;
      if (typeof obj.part.cost === "number") result.cost = obj.part.cost;
    }
  }
  result.text = chunks.join("");
  return result;
}

>> Prepends a system prompt to the user prompt.
>> Opencode has no per-invocation `--system` flag; agents carry their own prompts
>> and modifying the prompt text is the only per-call hook.
exe @prependOpencodeSystem(prompt, system) = js {
  const sys = typeof system === "string" ? system : "";
  const body = typeof prompt === "string" ? prompt : "";
  return sys ? sys + "\n\n" + body : body;
}

>> Reads the public and runtime-injected resume/session config for opencode.
>>
>> Public API:
>>   config.sessionId - explicit conversation tracking id
>>   config.resume    - explicit resume session id
>>
>> Runtime API:
>>   config._mlld.resume = { sessionId, provider, continue }
>>
>> Runtime resume is ignored when the recorded provider is not opencode so a
>> claude/codex session never leaks across providers.
exe @opencodeResume(config) = [
  let @cfg = @config ? @config : {}
  let @runtime = @cfg._mlld ? @cfg._mlld : {}
  let @resume = @runtime.resume ? @runtime.resume : {}
  let @runtimeProvider = @resume.provider ? @resume.provider : "opencode"
  let @runtimeSessionId = @normalizeOpencodeSessionId(@resume.sessionId)
  let @publicSessionId = @normalizeOpencodeSessionId(@cfg.sessionId)
  let @publicResumeId = @normalizeOpencodeSessionId(@cfg.resume)
  => when [
    @resume.continue && @runtimeSessionId && @runtimeProvider == "opencode" => {
      continue: true,
      sessionId: @runtimeSessionId,
      provider: "opencode",
      source: "runtime_resume"
    }
    @publicResumeId => {
      continue: true,
      sessionId: @publicResumeId,
      provider: "opencode",
      source: "public_resume"
    }
    @runtimeSessionId && @runtimeProvider == "opencode" => {
      continue: false,
      sessionId: @runtimeSessionId,
      provider: "opencode",
      source: "runtime_tracking"
    }
    @publicSessionId => {
      continue: false,
      sessionId: @publicSessionId,
      provider: "opencode",
      source: "public_session"
    }
    * => {
      continue: false,
      sessionId: null,
      provider: "opencode",
      source: "none"
    }
  ]
]

>> Wraps the result with a runtime-visible `_mlld` envelope so the interpreter
>> can harvest the session id and provider across guard-driven resume.
exe @opencodeResult(inputValue, resume) = when [
  @resume.sessionId => {
    value: @inputValue,
    _mlld: {
      sessionId: @resume.sessionId,
      provider: @resume.provider
    }
  }
  * => @inputValue
]

>> ── MCP bridge translation ──
>>
>> The runtime-generated MCP config at @mx.llm.config is a Claude-format JSON
>> `{ mcpServers: { name: { command, args, env, url } } }`. Opencode consumes MCP
>> servers via its `opencode.json` config under a top-level `mcp` key with shape:
>>
>>   { "mcp": { "name": { "type": "local", "command": ["node", "..."], "environment": {...} } } }
>>
>> Opencode has no per-call MCP flag and no `--config-file` override, but it honors
>> XDG_CONFIG_HOME for its config directory. We build a shadow config dir:
>>   - symlink every entry from the real $XDG_CONFIG_HOME/opencode into a tmp dir
>>     EXCEPT opencode.json / opencode.jsonc
>>   - merge the generated MCP entries into the user's opencode.json (if any)
>>     and write the result to the shadow dir
>>   - the sh wrapper exports XDG_CONFIG_HOME=<shadow> for that invocation
>>
>> Data (auth, sessions, snapshots) lives under $XDG_DATA_HOME which we don't
>> reroute, so auth and session history remain intact.
exe @opencodeMcpHome(configPath) = node {
  if (!configPath) return "";
  const fs = require('fs');
  const path = require('path');
  const os = require('os');
  if (!fs.existsSync(configPath)) return "";

  let parsed;
  try { parsed = JSON.parse(fs.readFileSync(configPath, 'utf8')); } catch { return ""; }
  const servers = parsed && parsed.mcpServers;
  if (!servers || typeof servers !== 'object' || !Object.keys(servers).length) {
    return "";
  }

  const translated = {};
  for (const [name, spec] of Object.entries(servers)) {
    if (!spec || typeof spec !== 'object') continue;
    if (!/^[A-Za-z_][A-Za-z0-9_-]*$/.test(name)) continue;
    if (typeof spec.url === 'string') {
      const headers = {};
      if (spec.headers && typeof spec.headers === 'object') {
        for (const [k, v] of Object.entries(spec.headers)) {
          if (typeof v === 'string') headers[k] = v;
        }
      }
      translated[name] = { type: 'remote', url: spec.url, headers };
      continue;
    }
    if (typeof spec.command !== 'string') continue;
    const argv = [spec.command];
    if (Array.isArray(spec.args)) {
      for (const a of spec.args) argv.push(String(a));
    }
    const environment = {};
    if (spec.env && typeof spec.env === 'object') {
      for (const [k, v] of Object.entries(spec.env)) {
        if (typeof v === 'string') environment[k] = v;
      }
    }
    translated[name] = { type: 'local', command: argv, environment, enabled: true };
  }
  if (!Object.keys(translated).length) return "";

  const sourceConfigHome = process.env.XDG_CONFIG_HOME || path.join(os.homedir(), '.config');
  const sourceOpencodeDir = path.join(sourceConfigHome, 'opencode');

  const shadowRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'mlld-opencode-home-'));
  const shadowOpencodeDir = path.join(shadowRoot, 'opencode');
  fs.mkdirSync(shadowOpencodeDir, { recursive: true });

  const skipNames = new Set(['opencode.json', 'opencode.jsonc', 'config.json']);
  if (fs.existsSync(sourceOpencodeDir)) {
    for (const entry of fs.readdirSync(sourceOpencodeDir)) {
      if (skipNames.has(entry)) continue;
      try {
        fs.symlinkSync(
          path.join(sourceOpencodeDir, entry),
          path.join(shadowOpencodeDir, entry)
        );
      } catch { /* best effort */ }
    }
  }

  let base = {};
  for (const candidate of ['config.json', 'opencode.json', 'opencode.jsonc']) {
    const p = path.join(sourceOpencodeDir, candidate);
    if (!fs.existsSync(p)) continue;
    try {
      const raw = fs.readFileSync(p, 'utf8');
      const stripped = candidate.endsWith('.jsonc')
        ? raw.replace(/\/\/.*$/gm, '').replace(/\/\*[\s\S]*?\*\//g, '')
        : raw;
      const userCfg = JSON.parse(stripped);
      if (userCfg && typeof userCfg === 'object') {
        base = { ...base, ...userCfg };
      }
    } catch { /* ignore malformed */ }
  }
  base.mcp = { ...(base.mcp && typeof base.mcp === 'object' ? base.mcp : {}), ...translated };

  fs.writeFileSync(
    path.join(shadowOpencodeDir, 'opencode.json'),
    JSON.stringify(base, null, 2),
    'utf8'
  );
  return shadowRoot;
}

>> ── Shell wrapper for opencode run ──
>>
>> Flat positional params so BashExecutor injects each one as a distinct env var.
>> Routing through sh {} with env vars sidesteps the mlld cmd-block double-escape
>> bug for interpolated values (see ticket m-8694).
exe @runOpencodeSh(prompt, dir, model, agent, variant, bypass, shadowHome, doResume, resumeId) = sh {
  set -e

  if [ -n "$shadowHome" ]; then
    export XDG_CONFIG_HOME="$shadowHome"
  fi

  dirFlag=()
  if [ -n "$dir" ]; then
    dirFlag=(--dir "$dir")
  fi

  modelFlag=()
  if [ -n "$model" ]; then
    modelFlag=(-m "$model")
  fi

  agentFlag=()
  if [ -n "$agent" ]; then
    agentFlag=(--agent "$agent")
  fi

  variantFlag=()
  if [ -n "$variant" ]; then
    variantFlag=(--variant "$variant")
  fi

  bypassFlag=()
  if [ -n "$bypass" ]; then
    bypassFlag=(--dangerously-skip-permissions)
  fi

  sessionFlag=()
  if [ -n "$doResume" ]; then
    sessionFlag=(-s "$resumeId")
  fi

  printf '%s' "$prompt" | opencode run --format json "${dirFlag[@]}" "${modelFlag[@]}" "${agentFlag[@]}" "${variantFlag[@]}" "${bypassFlag[@]}" "${sessionFlag[@]}"
}

>> ── Core invocation ──
>>
>> @opencode(prompt, config)
>> config.model     - provider/model string, e.g. "anthropic/claude-sonnet-4-5"
>> config.dir       - working directory (passed via --dir)
>> config.agent     - opencode agent name (--agent)
>> config.variant   - reasoning variant: "minimal" | "high" | "max" (--variant)
>> config.bypass    - boolean, passes --dangerously-skip-permissions
>> config.system    - prepended to the prompt (opencode has no per-call system flag)
>> config.stream    - JSONL streaming via stream adapter
>> config.sessionId - explicit tracking session id
>> config.resume    - explicit resume session id
>> config.tools     - mlld convention: runtime populates @mx.llm.config with a
>>                    generated MCP bridge JSON. We translate it into an
>>                    opencode.json mcp block and expose via XDG_CONFIG_HOME.
>>                    Note: opencode has no per-tool gating, so @mx.llm.native
>>                    filtering is informational only.
>>
>> Runtime notes:
>> - Always runs `opencode run --format json` so we can parse sessionID + text
>>   + usage regardless of streaming mode. In stream mode the stream adapter
>>   consumes `text` events as they arrive; @raw still holds the full NDJSON.
>> - Uses a `sh { }` block so interpolated values flow as bash env vars and
>>   survive unescaped (see ticket m-8694 for the `cmd` block escaping bug).
exe llm @opencode(prompt, config) = [
  let @cfg = @config ? @config : {}
  let @dir = @cfg.dir ? @cfg.dir : @root
  let @model = @cfg.model ? @cfg.model : "openrouter/z-ai/glm-5.1"
  let @agent = @cfg.agent ? @cfg.agent : ""
  let @variant = @cfg.variant ? @cfg.variant : ""
  let @bypass = @cfg.bypass ? "1" : ""
  let @shadowHome = @mx.llm && @mx.llm.config ? @opencodeMcpHome(@mx.llm.config) : ""
  let @finalPrompt = @cfg.system ? @prependOpencodeSystem(@prompt, @cfg.system) : @prompt
  let @resume = @opencodeResume(@cfg)
  let @doResume = @resume.continue && @resume.sessionId ? "1" : ""
  let @resumeId = @resume.sessionId ? @resume.sessionId : ""
  let @raw = @runOpencodeSh(@finalPrompt, @dir, @model, @agent, @variant, @bypass, @shadowHome, @doResume, @resumeId)
  let @parsed = @parseOpencodeJsonl(@raw)
  let @sessionId = @normalizeOpencodeSessionId(@parsed.sessionId ?? @resume.sessionId ?? null)
  let @value = when [
    @cfg.stream => @raw
    @parsed.text => @parsed.text
    * => @raw
  ]
  => @opencodeResult(@value, {
    sessionId: @sessionId,
    provider: "opencode",
    source: @resume.source
  })
] with { stream: @cfg.stream, streamFormat: @opencodeStreamFormat }

export { @opencode, @opencodeStreamFormat }
